run = "pip install -r requirements.txt && python app.py"
entrypoint = "app.py"

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "pip install -r requirements.txt && gunicorn app:app --bind 0.0.0.0:${PORT:-5000} --timeout 120 --worker-class gthread --threads 4"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 5000
externalPort = 80
